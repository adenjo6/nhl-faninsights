# Frontend Environment Variables

# Backend API URL
# Local development
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (replace with your Railway backend URL)
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# Sentry (frontend) — get DSN from sentry.io project settings
NEXT_PUBLIC_SENTRY_DSN=
# Optional: marks events with environment name (development | production)
NEXT_PUBLIC_ENV=development

# PostHog analytics — get key from posthog.com project settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com