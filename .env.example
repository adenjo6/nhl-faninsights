# ─────────────────────────────────────────────────────────────────────────────
# Root .env — read by `docker compose` and injected into the backend container.
# Copy to `.env` and fill in the keys you have. Only the values below are
# consumed by docker-compose.yml (DATABASE_URL, Redis, ports, etc. are set in
# compose directly). Secrets live ONLY here / backend — never in frontend env.
#
#   cp .env.example .env  &&  docker compose up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# YouTube Data API v3 — game highlight videos.
YOUTUBE_API_KEY=

# Anthropic API — AI recaps + Reddit sentiment analysis.
CLAUDE_API_KEY=

# Reddit (PRAW "script" app) — fan sentiment + game-thread comments.
# Leave blank + set REDDIT_USE_ANON=true to use the public JSON endpoints.
REDDIT_USE_ANON=false
REDDIT_USER_AGENT=python:nhl-fan-insights:1.0 (by /u/yourusername)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
