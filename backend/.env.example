# ─────────────────────────────────────────────────────────────────────────────
# Backend environment template. Copy to `backend/.env` (host run) or to a root
# `.env` (docker compose) and fill in real values. Keys map 1:1 to
# app/config.py (pydantic Settings). Missing optional keys silently disable the
# corresponding feature — they don't fail startup.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# Docker compose uses these credentials; for host runs point at your local PG.
DATABASE_URL=postgresql://nhluser:nhlpassword@localhost:5432/nhl
# Railway provides this automatically in production:
# DATABASE_URL=postgresql://user:password@railway.internal:5432/railway

# ── External APIs ────────────────────────────────────────────────────────────
# YouTube Data API v3 — required for game highlight videos.
YOUTUBE_API_KEY=
# Anthropic API — required for AI recaps and Reddit sentiment analysis.
CLAUDE_API_KEY=
# Model used for recaps/sentiment (see app/config.py default).
CLAUDE_MODEL=claude-sonnet-4-6

# ── Clerk Auth (optional — gates authenticated comment routes) ───────────────
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ── prospect-service (Go gRPC microservice) ──────────────────────────────────
# Unset → prospects endpoints soft-fail to empty. In docker compose this is
# set to "prospect-service:50051".
PROSPECT_SERVICE_ADDR=
# Per-call gRPC deadline in seconds.
PROSPECT_SERVICE_TIMEOUT=2.0

# ── Reddit (sentiment + game-thread comments) ────────────────────────────────
# PRAW "script" app credentials. Missing values make Reddit features no-op.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=python:nhl-fan-insights:1.0 (by /u/yourusername)
REDDIT_SUBREDDIT=SanJoseSharks
# true → use public reddit.com/.json (no auth, ~10 req/min); false → PRAW auth.
REDDIT_USE_ANON=false

# ── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Redis cache (optional — improves performance; no-op when disabled) ───────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Application settings ─────────────────────────────────────────────────────
SHARKS_TEAM_ID=SJS
BARRACUDA_TEAM_ID=SJB
TIMEZONE=America/Los_Angeles
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
